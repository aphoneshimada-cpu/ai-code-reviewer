{
  "name": "ai-code-reviewer",
  "version": "1.0.0",
  "description": "Automated code review bot using Xiaomi MiMo AI",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "lint": "eslint src/",
    "docker:build": "docker build -t ai-code-reviewer .",
    "docker:run": "docker run -p 3000:3000 --env-file .env ai-code-reviewer"
